'use client';

import { useRouter, useSearchParams } from 'next/navigation';
import { useEffect, useRef } from 'react';
import { supabase } from '@/lib/supabaseClient';

const EVENT_SOURCE = 'auth/callback/page.tsx';

function enqueueAuthEvent(event_type: string, meta: any = {}) {
  try {
    const qKey = 'bm_behavior_queue_v1';
    const item = {
      dedup_key: `${event_type}-${Date.now()}`,
      event_type,
      source: EVENT_SOURCE,
      created_at: new Date().toISOString(),
      metadata: meta,
    };
    let queue: any[] = [];
    try {
      queue = JSON.parse(localStorage.getItem(qKey) || '[]');
    } catch {}
    queue.push(item);
    localStorage.setItem(qKey, JSON.stringify(queue));
  } catch {}
}

async function flushAuthEvents(session: any) {
  const qKey = 'bm_behavior_queue_v1';
  let queue: any[] = [];
  try {
    queue = JSON.parse(localStorage.getItem(qKey) || '[]');
  } catch {}
  if (!queue.length) return;
  // Fire and forget: send to API or Supabase table if desired
  // await yourAPI.sendBehaviorEvents(queue, session?.user.id)
  localStorage.setItem(qKey, '[]');
}

export default function AuthCallbackPage() {
  const router = useRouter();
  const params = useSearchParams();
  const completed = useRef(false);

  useEffect(() => {
    if (completed.current) return;
    completed.current = true;

    async function handleAuth() {
      let session = null;
      let code = params.get('code');
      let error = null;
      let destination = params.get('next') || '/matches';

      // 1. Try PKCE code exchange first
      if (code) {
        try {
          const { data, error: exchError } = await supabase.auth.exchangeCodeForSession(code);
          if (exchError) {
            enqueueAuthEvent('auth.oauth_exchange_failed', { error: exchError.message, code });
          } else if (data.session) {
            session = data.session;
            enqueueAuthEvent('auth.oauth_callback_success', { method: 'exchangeCodeForSession' });
            await flushAuthEvents(session);
            router.replace(destination);
            return;
          }
        } catch (err: any) {
          enqueueAuthEvent('auth.oauth_exchange_failed', { error: err?.message || String(err), code });
        }
      }

      // 2. Try hash fragment tokens if present (email magic link, some Google flows)
      if (typeof window !== 'undefined' && window.location.hash) {
        try {
          const { data, error: hashError } = await supabase.auth.getSessionFromUrl({ storeSession: true });
          if (hashError) {
            enqueueAuthEvent('auth.oauth_hash_failed', { error: hashError.message });
          } else if (data.session) {
            session = data.session;
            enqueueAuthEvent('auth.oauth_callback_success', { method: 'getSessionFromUrl' });
            await flushAuthEvents(session);
            router.replace(destination);
            return;
          }
        } catch (err: any) {
          enqueueAuthEvent('auth.oauth_hash_failed', { error: err?.message || String(err) });
        }
      }

      // 3. Check for already-existing session (maybe tab already has it)
      try {
        const { data } = await supabase.auth.getSession();
        if (data.session) {
          session = data.session;
          enqueueAuthEvent('auth.session_detected');
          await flushAuthEvents(session);
          router.replace(destination);
          return;
        }
      } catch (err: any) {
        enqueueAuthEvent('auth.oauth_callback_failed', { error: err?.message || String(err) });
      }

      // 4. No luck - must throw error
      enqueueAuthEvent('auth.oauth_callback_failed', { error: 'No session found in url or by code' });
      await flushAuthEvents(null);
      router.replace('/auth?error=missing_code');
    }

    handleAuth();
  }, [params, router]);

  return (
    <div>
      <h2>Completing authentication…</h2>
      {/* Optionally render spinner/feedback */}
    </div>
  );
}
